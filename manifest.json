{
  "manifest_version": 3,
  "name": "Shorts Deleter",
  "version": "1.0",
  "description": "Remove YouTube Shorts from the interface",
  "id": "shorts-deleter@jgbed",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "content_scripts": [{
    "matches": ["*://*.youtube.com/*"],
    "js": ["content.js"]
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },
  "permissions": ["activeTab"],
  "browser_specific_settings": {
    "gecko": {
      "id": "shorts-deleter@jgbed",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}